{
  "expo": {
    "name": "Ogwu",
    "slug": "ogwu",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/ogwu-ios.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/ogwu-ios.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#ffffff",
        "foregroundImage": "./assets/ogwu-ios.png"
      },
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "favicon": "./assets/ogwu-ios.png"
    },
    "plugins": [
      "expo-localization",
      [
        "expo-calendar",
        {
          "calendarPermission": "Allow Ogwu to add your appointment to Apple Calendar."
        }
      ]
    ]
  }
}
