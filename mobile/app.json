{
  "expo": {
    "name": "Ogwu",
    "slug": "ogwu",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/ogwu.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/ogwu.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#450050",
        "foregroundImage": "./assets/ogwu.png"
      },
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "favicon": "./assets/ogwu.png"
    },
    "plugins": [
      "expo-localization"
    ]
  }
}
