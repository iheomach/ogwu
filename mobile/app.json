{
  "expo": {
    "name": "Ogwu",
    "slug": "ogwu",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/ogwu-ios.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/ogwu-ios.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#ffffff",
        "foregroundImage": "./assets/ogwu-ios.png"
      },
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.READ_CALENDAR",
        "android.permission.WRITE_CALENDAR"
      ]
    },
    "web": {
      "favicon": "./assets/ogwu-ios.png"
    },
    "plugins": [
      "expo-localization",
      "expo-notifications",
      [
        "expo-calendar",
        {
          "calendarPermission": "Allow Ogwu to add your appointment to Apple Calendar."
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "a9b03c5a-29e7-493c-9f5b-612f2895fbfa"
      }
    },
    "owner": "iheoma"
  }
  }